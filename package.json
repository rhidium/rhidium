{
  "name": "rhidium",
  "license": "ISC",
  "version": "4.0.0-alpha.1",
  "description": "Quickly and easily create powerful Discord bots using a powerful, opinionated, all-in-one framework.",
  "type": "module",
  "main": "./dist/index.mjs",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=16.6.0",
    "npm": ">=7.0.0",
    "vscode": "^1.22.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx ./prisma/seed.ts"
  },
  "files": [
    "./config",
    "./dist",
    "./locales",
    "./src",
    "./package.json"
  ],
  "scripts": {
    "build": "pkgroll --minify --sourcemap --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
    "build:watch": "pkgroll --watch",
    "prebuild": "rimraf dist",
    "clean": "gts clean; rimraf docs",
    "clean:full": "npm run clean; rimraf logs node_modules",
    "cp:locales": "node scripts/copy-locales.js",
    "dev": "npm run start:dev",
    "docs:build": "npx typedoc",
    "docs:watch": "npx typedoc --watch",
    "fix": "gts fix",
    "lint": "gts lint",
    "pretest": "npm run build",
    "posttest": "npm run lint",
    "start": "node --enable-source-maps dist/index.mjs",
    "start:dev": "DEBUG=app:* tsx watch src/index.ts",
    "test": "mocha dist/test/**/*.js",
    "test:dev": "ts-mocha test/**/*.spec.ts -w --watch-files '**/*.ts'",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "commit": "cz",
    "setup:linux": "pnpm install && cp .env.example .env && cp config/config.example.json config/config.json && cp config/extended-config.example.json config/extended-config.json",
    "setup:windows": "pnpm install && copy .env.example .env && copy config/config.example.json config/config.json && cp config/extended-config.example.json config/extended-config.json",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "prepare": "node .husky/install.mjs",
    "checks": "gts check && turbo run typecheck && turbo run test",
    "ci:cs": "pnpm changeset",
    "ci:publish": "pnpm publish -r",
    "ci:version": "pnpm changeset version",
    "up:bump:minor": "pnpm up",
    "up:bump:major": "pnpm up --latest"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "7.4.2",
    "cache-manager": "^7.2.8",
    "chrono-node": "^2.9.0",
    "colors": "^1.4.0",
    "common-tags": "^1.8.2",
    "cron": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "debug": "^4.4.3",
    "deep-object-diff": "^1.1.9",
    "discord.js": "^14.25.1",
    "i18next": "^25.8.13",
    "keyv": "^5.6.0",
    "lru-cache": "^11.2.6",
    "object-property-extractor": "^1.0.14",
    "pg": "^8.19.0",
    "prisma": "^7.4.2",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/common-tags": "^1.8.4",
    "@types/debug": "^4.1.12",
    "@types/node": "^25.3.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "gts": "^7.0.0",
    "husky": "^9.1.7",
    "pkgroll": "^2.27.0",
    "rimraf": "^6.1.3",
    "terser": "^5.46.0",
    "ts-json-schema-generator": "^2.5.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  },
  "author": {
    "name": "Richard Hillebrand (Mirasaki)",
    "email": "me@mirasaki.dev",
    "url": "https://mirasaki.dev"
  },
  "keywords": [
    "discord",
    "template",
    "bot-template",
    "node",
    "discordapp",
    "typescript",
    "rhidium",
    "framework",
    "discord.js"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:rhidium/rhidium.git"
  },
  "bugs": {
    "url": "https://github.com/rhidium/rhidium/issues"
  },
  "homepage": "https://github.com/rhidium/rhidium#readme",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
